---
import '../assets/styles/global.css';
import ClientEnhancements from '../components/client/ClientEnhancements.astro';

interface Props {
  title?: string;
}
const { title = 'RicePattyJulls' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700;800&family=JetBrains+Mono:wght@400;500;600&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-shell">
      <div class="bg-grid" aria-hidden="true"></div>
      <div class="ambient ambient-a" aria-hidden="true"></div>
      <div class="ambient ambient-b" aria-hidden="true"></div>
      <div class="ambient ambient-c" aria-hidden="true"></div>
      <main class="wide">
        <slot />
      </main>
      <ClientEnhancements />
    </div>
  </body>
</html>
