  </section>

  <div class="section-divider"></div>

  <!-- 11 / HYBRID AD PATHS -->
  <section id="hybrid-ad" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">11 / Hybrid AD Paths</span>
      <h2 class="section-title">Hybrid AD Paths</h2>
      <p class="section-copy">{azureSections['hybrid-ad-paths'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['hybrid-ad-paths'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">HYBRID AD</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 12 / OPERATOR TOOLKIT -->
  <section id="operator-toolkit" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">12 / Operator Toolkit</span>
      <h2 class="section-title">Operator Toolkit</h2>
      <p class="section-copy">{azureSections['operator-toolkit'].description}</p>
    </div>
    <div class="impact-banner" style="margin-top:1.5rem;">
      <div class="impact-icon"></div>
      <div class="impact-copy"><strong>Code lives on GitHub.</strong> The scripts below are operator tools built from CARTE lab work. No code is pasted inline on this page.</div>
    </div>
    <div class="path-grid" style="margin-top:2rem;">
      <a class="card" href="https://github.com/RicePattyJulls/tools/blob/main/AZURE/scripts/get_token.ps1" target="_blank" rel="noopener noreferrer" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;"><span class="index-badge">Module 01</span><code style="font-size:.8rem;color:var(--accent);">get_token.ps1</code></div>
        <h3 class="path-title" style="margin-bottom:.75rem;">Token Acquisition</h3>
        <p style="font-size:.9rem;color:#888;line-height:1.5;margin-bottom:1rem;">Multi-flow token acquisition: DCF, ROPC, auth code, client credentials (secret + certificate), browser extraction, and IMDS. Outputs AT + RT with FOCI detection.</p>
        <div class="path-foot"><span>PowerShell</span><span class="path-result">GitHub →</span></div>
      </a>
      <a class="card" href="https://github.com/RicePattyJulls/tools/blob/main/AZURE/scripts/recon.ps1" target="_blank" rel="noopener noreferrer" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;"><span class="index-badge">Module 02</span><code style="font-size:.8rem;color:var(--accent);">recon.ps1</code></div>
        <h3 class="path-title" style="margin-bottom:.75rem;">Tenant Recon</h3>
        <p style="font-size:.9rem;color:#888;line-height:1.5;margin-bottom:1rem;">Tenant structure mapping via Graph and ARM. Enumerates users, groups, SPs, app registrations, RBAC assignments, and CA policies. Outputs structured attack surface view.</p>
        <div class="path-foot"><span>PowerShell</span><span class="path-result">GitHub →</span></div>
      </a>
      <a class="card" href="https://github.com/RicePattyJulls/tools/blob/main/AZURE/scripts/entraid.ps1" target="_blank" rel="noopener noreferrer" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;"><span class="index-badge">Module 03</span><code style="font-size:.8rem;color:var(--accent);">entraId.ps1</code></div>
        <h3 class="path-title" style="margin-bottom:.75rem;">Identity Deep-Dive</h3>
        <p style="font-size:.9rem;color:#888;line-height:1.5;margin-bottom:1rem;">Per-principal analysis. Resolves directory roles, group memberships (transitive), app permissions, OAuth consents, and PIM eligible assignments for any user, SP, or managed identity.</p>
        <div class="path-foot"><span>PowerShell</span><span class="path-result">GitHub →</span></div>
      </a>
      <a class="card" href="https://github.com/RicePattyJulls/tools/blob/main/AZURE/scripts/ex_entraId.ps1" target="_blank" rel="noopener noreferrer" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem;"><span class="index-badge">Module 04</span><code style="font-size:.8rem;color:var(--accent);">ex_entraId.ps1</code></div>
        <h3 class="path-title" style="margin-bottom:.75rem;">Abuse Module</h3>
        <p style="font-size:.9rem;color:#888;line-height:1.5;margin-bottom:1rem;">Chains enumeration to abuse operations — PIM activation, group manipulation, consent grants, token pivoting. Operates on the identity surface mapped by entraId.</p>
        <div class="path-foot"><span>PowerShell</span><span class="path-result">GitHub →</span></div>
