---
import BaseLayout from '../layouts/BaseLayout.astro';
import AzureNav from '../components/layout/AzureNav.astro';
import { azureSections, azureTechniquesBySection } from '../data/azure';
---
<BaseLayout title="Azure | RicePattyJulls">
  <AzureNav active="overview" />

  <!-- 00 / OVERVIEW -->
  <section id="overview" class="hero section-block" style="scroll-margin-top:80px;">
    <h1 class="hero-title"><span class="accent-text">Azure</span> / Entra ID</h1>
    <span class="section-tag" style="display:inline-block;margin-top:2.5rem;">00 / Overview</span>
    <p class="hero-copy">
      Microsoft Entra ID is the identity control plane for Azure — and identity is the perimeter.
      Every resource access decision flows through OAuth 2.0 tokens, Conditional Access policies,
      role assignments, and service principal permissions. Understanding what each token can reach,
      how it was acquired, and where CA gaps exist defines the attack surface.
    </p>
    <p class="hero-copy" style="margin-top:1rem;">
      This section covers Entra ID offensive operations from initial token acquisition through
      cross-tenant privilege projection: device code phishing, FOCI abuse, Graph and ARM manipulation,
      Key Vault data plane extraction, Managed Identity IMDS abuse, and hybrid on-prem pivots.
    </p>
    <div class="hero-stats">
      <div class="card stat-card hot"><p class="stat-value">12</p><span class="stat-label">Attack Surfaces</span></div>
      <div class="card stat-card"><p class="stat-value">35</p><span class="stat-label">Documented Techniques</span></div>
      <div class="card stat-card hot"><p class="stat-value">OAuth 2.0</p><span class="stat-label">Token-Based Attack Surface</span></div>
      <div class="card stat-card"><p class="stat-value">CARTE</p><span class="stat-label">Certification Material</span></div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 01 / IDENTITY & TOKEN MODEL -->
  <section id="identity-tokens" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">01 / Identity & Token Model</span>
      <h2 class="section-title">Identity &amp; Token Model</h2>
      <p class="section-copy">{azureSections['identity-token-model'].description}</p>
    </div>
    <div class="path-grid" style="margin-top:2rem;">
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Token Types</span></div>
        <h3 class="path-title" style="margin-bottom:1rem;">Three Artifacts, Three Attack Values</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span><strong>Access Token (AT)</strong> — Short-lived (~1h). Bearer credential scoped to a specific resource audience. Stealing an AT = scoped access without credentials.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>Refresh Token (RT)</strong> — Long-lived (90 days active). Exchanges for new ATs without re-authentication. RT theft = persistent access across resource pivots.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>ID Token</strong> — Identity assertion only. Tells the app who the user is. Not usable as bearer credential against APIs.</span></div>
        </div>
      </div>
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Acquisition Flows</span></div>
        <h3 class="path-title" style="margin-bottom:1rem;">How Tokens Are Obtained</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span><strong>Device Code Flow</strong> — Attacker initiates; victim authenticates. Token lands on attacker side. MFA-resistant if CA doesn't block the flow.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>Client Credentials</strong> — App authenticates with secret or certificate. No user involved. Primary flow for Service Principal abuse.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>ROPC</strong> — Username + password directly to token endpoint. Bypasses interactive MFA prompts. Present in legacy tenants where CA is weak.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>IMDS</strong> — From compromised Azure compute. No credentials needed — the VM or container identity is the auth material.</span></div>
        </div>
      </div>
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Attack Surface</span></div>
        <h3 class="path-title" style="margin-bottom:1rem;">Where Tokens Live</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span><strong>Browser</strong> — MSAL.js session storage, cookies. Accessible via XSS or compromised browser session.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>CLI</strong> — <code>~/.azure/</code> token cache, system keychain. Present on any machine running Azure CLI or Az PowerShell module.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>App runtime</strong> — In-memory MSAL cache, environment variables, App Service config slots.</span></div>
          <div class="path-step"><span class="path-dot"></span><span><strong>IMDS endpoint</strong> — <code>169.254.169.254/metadata/identity/oauth2/token</code> — callable from Azure compute without credentials.</span></div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 02 / INITIAL ACCESS -->
  <section id="initial-access" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">02 / Initial Access</span>
      <h2 class="section-title">Initial Access</h2>
      <p class="section-copy">{azureSections['initial-access'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['initial-access'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">INITIAL ACCESS</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 03 / RECON & ENUMERATION -->
  <section id="recon" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">03 / Recon & Enumeration</span>
      <h2 class="section-title">Recon &amp; Enumeration</h2>
      <p class="section-copy">{azureSections['recon-enumeration'].description}</p>
    </div>
    <div class="path-grid" style="margin-top:2rem;">
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Phase 1</span><code style="font-size:.8rem;color:var(--accent);">get_token</code></div>
        <h3 class="path-title" style="margin-bottom:1rem;">Token Acquisition</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span>Multi-flow acquisition: DCF, ROPC, auth code, client credentials, certificate assertion, browser extraction.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Outputs AT + RT per identity per scope. Detects FOCI eligibility in response.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Scope selection: <code>graph</code>, <code>arm</code>, <code>keyvault</code>, <code>storage</code> — maps to a different attack plane.</span></div>
        </div>
        <div class="path-foot" style="margin-top:1rem;"><span>Permissions: varies by flow</span><span class="path-result">→ GitHub</span></div>
      </div>
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Phase 2</span><code style="font-size:.8rem;color:var(--accent);">recon</code></div>
        <h3 class="path-title" style="margin-bottom:1rem;">Tenant Mapping</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span>Maps tenant structure: users, groups, service principals, app registrations, device objects.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Enumerates Conditional Access policies — surfaces gaps, excluded apps, excluded users, session conditions.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Maps RBAC assignments across subscriptions. Surfaces Owner, Contributor, and custom roles on high-value resources.</span></div>
        </div>
        <div class="path-foot" style="margin-top:1rem;"><span>Needs: Graph AT, ARM AT</span><span class="path-result">→ GitHub</span></div>
      </div>
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Phase 3</span><code style="font-size:.8rem;color:var(--accent);">entraId</code></div>
        <h3 class="path-title" style="margin-bottom:1rem;">Identity Deep-Dive</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span>Per-principal analysis: directory roles, group memberships, app permissions, OAuth consent grants, PIM eligible assignments.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Resolves transitive memberships and nested group chains. Surfaces non-obvious privilege paths.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Input: any principal (user, SP, managed identity). Output: full privilege surface for that identity.</span></div>
        </div>
        <div class="path-foot" style="margin-top:1rem;"><span>Needs: Graph AT (Directory.Read)</span><span class="path-result">→ GitHub</span></div>
      </div>
      <div class="card" style="padding:1.5rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;"><span class="index-badge">Phase 4</span><code style="font-size:.8rem;color:var(--accent);">ex_entraId</code></div>
        <h3 class="path-title" style="margin-bottom:1rem;">Abuse Chaining</h3>
        <div class="path-steps">
          <div class="path-step"><span class="path-dot"></span><span>Connects identity context from Phase 3 to abuse operations — role activation, group manipulation, consent grants, token pivoting.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Operates on the identity surface identified during enumeration — no blind spraying.</span></div>
          <div class="path-step"><span class="path-dot"></span><span>Output: privilege escalation paths, token material for downstream abuse, lateral movement targets.</span></div>
        </div>
        <div class="path-foot" style="margin-top:1rem;"><span>Needs: scoped AT per target plane</span><span class="path-result">→ GitHub</span></div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 04 / GRAPH ABUSE -->
  <section id="graph" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">04 / Graph Abuse</span>
      <h2 class="section-title">Microsoft Graph Abuse</h2>
      <p class="section-copy">{azureSections['graph-abuse'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['graph-abuse'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">GRAPH ABUSE</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 05 / ARM ABUSE -->
  <section id="arm" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">05 / ARM Abuse</span>
      <h2 class="section-title">ARM Abuse</h2>
      <p class="section-copy">{azureSections['arm-abuse'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['arm-abuse'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">ARM ABUSE</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 06 / AZURE STORAGE ABUSE -->
  <section id="storage" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">06 / Azure Storage Abuse</span>
      <h2 class="section-title">Azure Storage Abuse</h2>
      <p class="section-copy">{azureSections['storage-abuse'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['storage-abuse'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">STORAGE ABUSE</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 07 / KEY VAULT ABUSE -->
  <section id="key-vault" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">07 / Key Vault Abuse</span>
      <h2 class="section-title">Key Vault Abuse</h2>
      <p class="section-copy">{azureSections['key-vault-abuse'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['key-vault-abuse'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">KEY VAULT ABUSE</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 08 / MANAGED IDENTITIES -->
  <section id="managed-identities" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">08 / Managed Identities</span>
      <h2 class="section-title">Managed Identities</h2>
      <p class="section-copy">{azureSections['managed-identities'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['managed-identities'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">MANAGED IDENTITIES</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 09 / AUTOMATION / LOGIC APPS / ARC -->
  <section id="automation" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">09 / Automation & Orchestration</span>
      <h2 class="section-title">Automation / Logic Apps / Arc</h2>
      <p class="section-copy">{azureSections['automation-logic-arc'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['automation-logic-arc'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">AUTOMATION & ORCH</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- 10 / CROSS-TENANT & B2B -->
  <section id="cross-tenant-b2b" class="section-block" style="scroll-margin-top:80px;">
    <div class="section-header">
      <span class="section-tag">10 / Cross-Tenant & B2B</span>
      <h2 class="section-title">Cross-Tenant &amp; B2B</h2>
      <p class="section-copy">{azureSections['cross-tenant-b2b'].description}</p>
    </div>
    <div class="path-grid">
      {azureTechniquesBySection['cross-tenant-b2b'].map((tech, index) => (
        <a class="card path-card" href={`/azure/${tech.slug}`}>
          <div class="path-head"><span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span><span style="font-size:.95rem;">🔥</span></div>
          <h3 class="path-title">{tech.title}</h3>
          <div class="path-steps">{tech.summary.map((step) => (<div class="path-step"><span class="path-dot"></span><span>{step}</span></div>))}</div>
          <div class="path-foot"><span>{tech.tags.join(' · ')}</span><span class="path-result">CROSS-TENANT</span></div>
        </a>
      ))}
