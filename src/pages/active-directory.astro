---
import BaseLayout from '../layouts/BaseLayout.astro';
import ActiveDirectoryNav from '../components/layout/ActiveDirectoryNav.astro';
import { adSections, adTechniquesBySection } from '../data/activeDirectory';

const orderedSections = ['credential-access', 'delegation', 'domain-dominance', 'trusts'] as const;
---
<BaseLayout title="Active Directory | RicePattyJulls">
  <ActiveDirectoryNav active="overview" />

  <section id="overview" class="hero section-block">
    <h1 class="hero-title"><span class="accent-text">Active Directory</span> Operations</h1>
    <span class="section-tag" style="display:inline-block; margin-top: 2.5rem;">01 / Main</span>
    <p class="hero-copy">
      Active Directory is Microsoft’s centralized database for managing identity and access across a network, allowing administrators to control who has permission to use
      resources such as files, printers, or applications from a single place. It works like a digital “master key” that authenticates users and ensures each person can access
      only what they need, making large-scale administration of systems across an organization much easier.
    </p>
  </section>

  <div class="section-divider"></div>

  {orderedSections.map((key) => {
    const section = adSections[key];
    const techniques = adTechniquesBySection[key];
    return (
      <>
        <section id={key} class="section-block">
          <div class="section-header">
            <span class="section-tag">{section.tag}</span>
            <h2 class="section-title">{section.title}</h2>
            <p class="section-copy">{section.description}</p>
          </div>

          <div class="path-grid">
            {techniques.map((tech, index) => (
              <a class="card path-card" href={`/active-directory/${tech.slug}`}>
                <div class="path-head">
                  <span class="index-badge">Technique {String(index + 1).padStart(2, '0')}</span>
                  <span style="font-size: .95rem;">🔥</span>
                </div>
                <h3 class="path-title">{tech.title}</h3>
                <div class="path-steps">
                  {tech.summary.map((step) => (
                    <div class="path-step">
                      <span class="path-dot"></span>
                      <span>{step}</span>
                    </div>
                  ))}
                </div>
                <div class="path-foot">
                  <span>{tech.tags.join(' · ')}</span>
                  <span class="path-result">{section.title.toUpperCase()}</span>
                </div>
              </a>
            ))}
          </div>
        </section>

        {key !== 'trusts' && <div class="section-divider"></div>}
      </>
    );
  })}

  <div class="footer-note">
    <span>Active Directory · Technique Reference</span>
    <span>Technique index · Per-technique reference pages</span>
  </div>
</BaseLayout>
